# Browser calls Django directly — absolute URL, exposed to browser code.
# If you set just a host, /api/v1 is auto-appended:
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8000  →  /api/v1
NEXT_PUBLIC_API_URL=/api/v1

# Server Components / SSR base (defaults to NEXT_PUBLIC_API_URL if unset).
API_URL=http://127.0.0.1:8000/api/v1

# Subscription payments: simulate (default) calls mark_paid on Pay now.
# Set to gateway when a real payment provider is wired.
# NEXT_PUBLIC_PAYMENT_MODE=simulate
