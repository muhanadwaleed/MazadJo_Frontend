# Browser client — use relative path so Next.js rewrites to Django (see next.config.ts)
NEXT_PUBLIC_API_URL=/api/v1

# If you set a host root only, the app auto-appends /api/v1:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000  →  http://127.0.0.1:8000/api/v1

# Server Components / SSR (must reach Django directly)
API_URL=http://127.0.0.1:8000/api/v1

# Optional: override proxy target (default http://127.0.0.1:8000)
# API_PROXY_TARGET=http://127.0.0.1:8000
