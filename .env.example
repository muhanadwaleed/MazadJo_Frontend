# Browser calls Django directly — MUST be an absolute URL (NEXT_PUBLIC_ is
# exposed to browser code). Django CORS must allow the frontend origin.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Server Components / SSR base. Defaults to NEXT_PUBLIC_API_URL if unset.
# On Railway you may point this at the backend's private network URL.
API_URL=http://127.0.0.1:8000/api/v1
